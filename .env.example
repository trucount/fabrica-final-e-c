# Supabase (required for editable content, products, orders, users, and invites)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY= # optional browser-safe alias if you prefer it

# SPARROW chatbot / OpenRouter (required for AI replies)
OPENROUTER_API_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Umami analytics API (required for admin Analytics live Umami graphs)
UMAMI_API_KEY=
UMAMI_API_CLIENT_ENDPOINT=https://api.umami.is/v1
UMAMI_WEBSITE_ID=c20d65b2-a78a-44f3-9d1b-62abfcb63d56

# Optional: embed a public/shared Umami dashboard iframe in Admin > Analytics
NEXT_PUBLIC_UMAMI_SHARE_URL=

# Razorpay (only required if Razorpay checkout is enabled)
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
